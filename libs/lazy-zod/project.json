{
  "name": "lazy-zod",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/lazy-zod/src",
  "projectType": "library",
  "tags": ["scope:libs", "scope:publishable", "versioning:synchronized"],
  "targets": {
    "build-cjs": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/lazy-zod/dist",
        "main": "libs/lazy-zod/src/index.ts",
        "tsConfig": "libs/lazy-zod/tsconfig.lib.json",
        "format": ["cjs"],
        "declaration": true,
        "declarationRootDir": "libs/lazy-zod/src",
        "bundle": true,
        "thirdParty": false,
        "platform": "node",
        "assets": ["libs/lazy-zod/README.md", "libs/lazy-zod/CHANGELOG.md", "LICENSE", "libs/lazy-zod/package.json"],
        "esbuildOptions": {
          "outExtension": {
            ".js": ".js"
          },
          "external": ["zod"]
        }
      },
      "dependsOn": ["^build"]
    },
    "build-esm": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["build-cjs"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/lazy-zod/dist/esm",
        "main": "libs/lazy-zod/src/index.ts",
        "tsConfig": "libs/lazy-zod/tsconfig.lib.json",
        "format": ["esm"],
        "declaration": false,
        "bundle": true,
        "thirdParty": false,
        "platform": "node",
        "esbuildOptions": {
          "outExtension": {
            ".js": ".mjs"
          },
          "external": ["zod"]
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-cjs", "build-esm"],
      "options": {
        "command": "node scripts/strip-dist-from-pkg.js libs/lazy-zod/dist/package.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/unit/lazy-zod"],
      "options": {
        "jestConfig": "libs/lazy-zod/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm publish libs/lazy-zod/dist --access public --registry=https://registry.npmjs.org/"
      }
    },
    "publish-alpha": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "bash scripts/publish-alpha.sh {projectRoot}/dist",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
