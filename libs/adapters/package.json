{
  "name": "@frontmcp/adapters",
  "version": "1.5.0-rc.1",
  "description": "Adapters for the FrontMCP framework",
  "author": "AgentFront <info@agentfront.dev>",
  "homepage": "https://docs.agentfront.dev",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "adapters",
    "agentfront",
    "frontmcp",
    "framework",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentfront/frontmcp.git",
    "directory": "libs/adapters"
  },
  "bugs": {
    "url": "https://github.com/agentfront/frontmcp/issues"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.mjs"
      }
    },
    "./openapi": {
      "development": "./src/openapi/index.ts",
      "require": {
        "types": "./dist/openapi/index.d.ts",
        "default": "./dist/openapi/index.js"
      },
      "import": {
        "types": "./dist/openapi/index.d.ts",
        "default": "./dist/esm/openapi/index.mjs"
      }
    },
    "./skills": {
      "development": "./src/skills/index.ts",
      "require": {
        "types": "./dist/skills/index.d.ts",
        "default": "./dist/skills/index.js"
      },
      "import": {
        "types": "./dist/skills/index.d.ts",
        "default": "./dist/esm/skills/index.mjs"
      }
    },
    "./esm": null
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@frontmcp/auth": "1.5.0-rc.1",
    "@frontmcp/di": "1.5.0-rc.1",
    "@frontmcp/sdk": "1.5.0-rc.1",
    "@frontmcp/utils": "1.5.0-rc.1",
    "js-yaml": "^4.1.0",
    "mcp-from-openapi": "2.4.0",
    "openapi-types": "^12.1.3"
  },
  "peerDependencies": {
    "@frontmcp/lazy-zod": "1.5.0-rc.1"
  }
}
