{
  "name": "observability",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/observability/src",
  "projectType": "library",
  "tags": ["scope:libs", "scope:publishable", "versioning:synchronized"],
  "targets": {
    "build-cjs": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": [],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/observability/dist",
        "main": "libs/observability/src/index.ts",
        "tsConfig": "libs/observability/tsconfig.lib.json",
        "format": ["cjs"],
        "declaration": true,
        "declarationRootDir": "libs/observability/src",
        "bundle": true,
        "thirdParty": false,
        "platform": "node",
        "assets": [
          "libs/observability/README.md",
          "libs/observability/CHANGELOG.md",
          "LICENSE",
          "libs/observability/package.json"
        ],
        "esbuildOptions": {
          "outExtension": { ".js": ".js" },
          "external": [
            "@frontmcp/sdk",
            "@frontmcp/utils",
            "@frontmcp/di",
            "@opentelemetry/api",
            "@opentelemetry/sdk-trace-base",
            "@opentelemetry/sdk-node",
            "@opentelemetry/exporter-trace-otlp-http",
            "winston",
            "pino",
            "zod"
          ]
        }
      }
    },
    "build-esm": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["build-cjs"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/observability/dist/esm",
        "main": "libs/observability/src/index.ts",
        "tsConfig": "libs/observability/tsconfig.lib.json",
        "format": ["esm"],
        "declaration": false,
        "bundle": true,
        "thirdParty": false,
        "platform": "node",
        "esbuildOptions": {
          "outExtension": { ".js": ".mjs" },
          "external": [
            "@frontmcp/sdk",
            "@frontmcp/utils",
            "@frontmcp/di",
            "@opentelemetry/api",
            "@opentelemetry/sdk-trace-base",
            "@opentelemetry/sdk-node",
            "@opentelemetry/exporter-trace-otlp-http",
            "winston",
            "pino",
            "zod"
          ]
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-cjs", "build-esm"],
      "options": {
        "command": "node scripts/strip-dist-from-pkg.js libs/observability/dist/package.json"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/unit/observability"],
      "options": {
        "jestConfig": "libs/observability/jest.config.ts",
        "passWithNoTests": false
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm publish libs/observability/dist --access public --registry=https://registry.npmjs.org/"
      }
    },
    "publish-alpha": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "bash scripts/publish-alpha.sh {projectRoot}/dist",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
