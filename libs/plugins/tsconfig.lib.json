{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "declarationMap": true,
    "types": ["node"],
    "paths": {
      "@frontmcp/lazy-zod": ["libs/lazy-zod/dist/index.d.ts"],
      "@frontmcp/sdk": ["libs/sdk/dist/index.d.ts"],
      "@frontmcp/plugin-cache": ["plugins/plugin-cache/dist/index.d.ts"],
      "@frontmcp/plugin-codecall": ["plugins/plugin-codecall/dist/index.d.ts"],
      "@frontmcp/plugin-dashboard": ["plugins/plugin-dashboard/dist/index.d.ts"],
      "@frontmcp/plugin-remember": ["plugins/plugin-remember/dist/index.d.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/__tests__/**", "src/**/__test-utils__/**"]
}
