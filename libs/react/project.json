{
  "name": "react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/react/src",
  "projectType": "library",
  "tags": ["scope:libs", "scope:publishable", "versioning:synchronized"],
  "targets": {
    "build-cjs": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["^build"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/react/dist",
        "main": "libs/react/src/index.ts",
        "tsConfig": "libs/react/tsconfig.lib.json",
        "format": ["cjs"],
        "declaration": true,
        "declarationRootDir": "libs/react/src",
        "bundle": true,
        "thirdParty": false,
        "platform": "neutral",
        "assets": ["libs/react/README.md", "LICENSE", "libs/react/package.json"],
        "additionalEntryPoints": ["libs/react/src/ai/index.ts", "libs/react/src/router/index.ts"],
        "esbuildOptions": {
          "outExtension": { ".js": ".js" },
          "external": [
            "@frontmcp/sdk",
            "@frontmcp/sdk/*",
            "@frontmcp/utils",
            "@frontmcp/utils/*",
            "react",
            "react-dom",
            "react/*",
            "react-dom/*",
            "react-router-dom",
            "react-router-dom/*",
            "zod",
            "reflect-metadata"
          ]
        }
      }
    },
    "build-esm": {
      "executor": "@nx/esbuild:esbuild",
      "dependsOn": ["build-cjs"],
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "libs/react/dist/esm",
        "main": "libs/react/src/index.ts",
        "tsConfig": "libs/react/tsconfig.lib.json",
        "format": ["esm"],
        "declaration": false,
        "bundle": true,
        "thirdParty": false,
        "platform": "neutral",
        "additionalEntryPoints": ["libs/react/src/ai/index.ts", "libs/react/src/router/index.ts"],
        "esbuildOptions": {
          "outExtension": { ".js": ".mjs" },
          "external": [
            "@frontmcp/sdk",
            "@frontmcp/sdk/*",
            "@frontmcp/utils",
            "@frontmcp/utils/*",
            "react",
            "react-dom",
            "react/*",
            "react-dom/*",
            "react-router-dom",
            "react-router-dom/*",
            "zod",
            "reflect-metadata"
          ]
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["build-cjs", "build-esm"],
      "options": {
        "command": "node scripts/strip-dist-from-pkg.js libs/react/dist/package.json"
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "npm publish libs/react/dist --access public --registry=https://registry.npmjs.org/"
      }
    },
    "publish-alpha": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "bash scripts/publish-alpha.sh {projectRoot}/dist",
        "cwd": "{workspaceRoot}"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/libs/react"],
      "options": {
        "jestConfig": "libs/react/jest.config.ts",
        "passWithNoTests": false
      }
    }
  }
}
