{
  "name": "@frontmcp/sdk",
  "version": "1.0.0-beta.14",
  "description": "FrontMCP SDK",
  "author": "AgentFront <info@agentfront.dev>",
  "homepage": "https://docs.agentfront.dev",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "dependency injection",
    "sdk",
    "adapters",
    "plugins",
    "agentfront",
    "frontmcp",
    "framework",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/agentfront/frontmcp.git"
  },
  "bugs": {
    "url": "https://github.com/agentfront/frontmcp/issues"
  },
  "imports": {
    "#sse-transport": {
      "browser": "./src/transport/adapters/polyfills/browser-sse-transport.ts",
      "default": "./src/transport/adapters/polyfills/node-sse-transport.ts"
    },
    "#express-host": {
      "browser": "./src/server/adapters/polyfills/browser-express-host.ts",
      "default": "./src/server/adapters/polyfills/node-express-host.ts"
    }
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/esm/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "development": "./src/index.ts",
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/esm/index.mjs"
      }
    },
    "./transport": {
      "development": "./src/transport/index.ts",
      "require": {
        "types": "./dist/transport/index.d.ts",
        "default": "./dist/transport/index.js"
      },
      "import": {
        "types": "./dist/transport/index.d.ts",
        "default": "./dist/esm/transport/index.mjs"
      }
    },
    "./esm": null
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "peerDependencies": {
    "zod": "^4.0.0",
    "zod-from-json-schema": "^0.5.2",
    "express": "^4.18.0 || ^5.0.0",
    "cors": "^2.8.5",
    "raw-body": "^3.0.0",
    "content-type": "^1.0.5",
    "@vercel/kv": "^3.0.0",
    "@frontmcp/storage-sqlite": "1.0.0-beta.14",
    "@enclave-vm/core": "^2.11.1",
    "openai": "^4.0.0 || ^5.0.0 || ^6.0.0",
    "@anthropic-ai/sdk": "^0.30.0 || ^0.78.0",
    "@frontmcp/observability": "1.0.0-beta.14",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-trace-base": "^1.25.0"
  },
  "peerDependenciesMeta": {
    "@vercel/kv": {
      "optional": true
    },
    "@frontmcp/storage-sqlite": {
      "optional": true
    },
    "@enclave-vm/core": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@frontmcp/observability": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/sdk-trace-base": {
      "optional": true
    }
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@frontmcp/utils": "1.0.0-beta.14",
    "@frontmcp/guard": "1.0.0-beta.14",
    "@frontmcp/di": "1.0.0-beta.14",
    "@frontmcp/uipack": "1.0.0-beta.14",
    "@frontmcp/auth": "1.0.0-beta.14",
    "@frontmcp/protocol": "1.0.0-beta.14",
    "ioredis": "^5.8.0",
    "vectoriadb": "^2.1.3",
    "js-yaml": "^4.1.1",
    "jose": "^6.1.3",
    "reflect-metadata": "^0.2.2",
    "semver": "^7.6.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
