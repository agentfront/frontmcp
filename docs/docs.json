{
  "$schema": "https://mintlify.com/docs.json",
  "name": "FrontMCP",
  "description": "A TypeScript-first framework for building production ready Model Context Protocol (MCP) servers",
  "appearance": {
    "default": "system",
    "strict": false
  },
  "theme": "almond",
  "favicon": {
    "light": "/assets/logo/favicon-32x32.png",
    "dark": "/assets/logo/favicon.dark.ico"
  },
  "logo": {
    "light": "/assets/logo/frontmcp.light.png",
    "dark": "/assets/logo/frontmcp.dark.png"
  },
  "colors": {
    "primary": "#16A34A",
    "light": "#07C983",
    "dark": "#15803D"
  },
  "contextual": {
    "options": ["copy", "chatgpt", "cursor", "mcp", "view"]
  },
  "interaction": {
    "drilldown": true
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "canonical": "https://docs.agentfront.dev/frontmcp",
      "og:image": "/assets/logo/banner.dark.png",
      "charset": "UTF-8",
      "viewport": "width=device-width, initial-scale=1.0",
      "keywords": "mcp, model context protocol, ai agents, llm tools, claude, openai, anthropic, ai sdk, typescript, dependency injection, decorators, zod, json-schema, openapi, api validation, type safety, runtime validation, mcp server, mcp framework, frontmcp, agentfront, ai tools, agent framework, streamable http, oauth, authentication"
    }
  },
  "navbar": {
    "links": [
      {
        "href": "https://github.com/agentfront/frontmcp/tree/main/apps/demo",
        "icon": "github",
        "label": "Examples"
      }
    ],
    "primary": {
      "href": "https://github.com/agentfront/frontmcp",
      "type": "github"
    }
  },
  "search": {
    "prompt": "Search the FrontMCP docs..."
  },
